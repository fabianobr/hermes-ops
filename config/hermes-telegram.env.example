# Telegram gateway example for Hermes host-side .env wiring.
# Copy only the keys you need into ~/.hermes/.env on the host.
# Do not commit real secrets.

# Required: Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=1234567890:replace-with-real-token

# Recommended for the first bring-up: restrict access to known operator IDs.
# Comma-separated Telegram numeric user IDs.
TELEGRAM_ALLOWED_USERS=123456789

# Optional: default Telegram destination for cron jobs and proactive messages.
# Use the numeric chat ID. For topics, set TELEGRAM_HOME_CHANNEL_THREAD_ID too.
# TELEGRAM_HOME_CHANNEL=-1001234567890
# TELEGRAM_HOME_CHANNEL_NAME=Hermes Home
# TELEGRAM_HOME_CHANNEL_THREAD_ID=17585
# TELEGRAM_CRON_THREAD_ID=17585

# Optional group controls for polling-mode deployments.
# TELEGRAM_ALLOWED_CHATS=-1001234567890
# TELEGRAM_GROUP_ALLOWED_CHATS=-1001234567890
# TELEGRAM_ALLOWED_TOPICS=17585
# TELEGRAM_REPLY_TO_MODE=first

# Optional proxy for regions/networks where Telegram is blocked.
# TELEGRAM_PROXY=socks5://127.0.0.1:1080

# Optional webhook mode. Omit all three keys to stay in long polling mode.
# TELEGRAM_WEBHOOK_URL=https://example.invalid/telegram
# TELEGRAM_WEBHOOK_PORT=8443
# TELEGRAM_WEBHOOK_SECRET=replace-with-random-secret
